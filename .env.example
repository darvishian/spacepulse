# Cesium Ion Token for map tiles and terrain (get one at https://ion.cesium.com)
NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# API base URL — leave empty or /api for Vercel, set to http://localhost:3001/api for local dev with Express backend
NEXT_PUBLIC_API_URL=/api

# WebSocket URL for real-time updates (only needed with Express backend)
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# YouTube Data API v3 key (free tier: 10k units/day) — required for live stream search
YOUTUBE_API_KEY=

# Development settings
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_DISABLE_ANIMATIONS=false
